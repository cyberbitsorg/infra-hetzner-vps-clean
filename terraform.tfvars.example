# =============================================================================
# Hetzner Cloud API Token
# Create at: https://console.hetzner.cloud/ -> Project -> Security -> API Tokens
# =============================================================================

hcloud_token = "<insert api token>"

# =============================================================================
# Server configuration
# =============================================================================

server_name     = "fsn-web01"
server_type     = "cx33"          # cx23=2CPU/4GB, cx33=4CPU/8GB, cx43=8CPU/16GB
server_location = "fsn1"          # fsn1=Falkenstein, nbg1=Nuremberg, hel1=Helsinki
server_image    = "ubuntu-24.04"  # Deployment is optimized for Ubuntu
server_backups  = true            # Recommended! But +20% cost

# =============================================================================
# SSH configuration
# =============================================================================

# SSH key must already exist in Hetzner Cloud.
# Create it first using https://github.com/cyberbitsorg/infra-hetzner-ssh
# then reference the key name here.

ssh_public_key_path = "~/.ssh/id_ed25519.pub"
ssh_key_name        = "main-deploy-key"

# =============================================================================
# Admin user
# =============================================================================

admin_username = "<insert admin name>"          # Linux admin name
admin_email    = "<insert admin email>"         # Linux admin email
timezone       = "Europe/Amsterdam"             # Server timezone

# =============================================================================
# Domain configuration
# =============================================================================

# Base domain used to construct FQDN: <server_name>.<base_domain>
# Example: server_name "fsn-web01" + base_domain "example.com" = "fsn-web01.example.com"
base_domain = "example.com"

# Email sender prefix for system alerts (e.g., fail2ban)
# Full sender will be: <system_email_prefix>@<base_domain>
# Example: "fail2ban" becomes "fail2ban@example.com"
system_email_prefix = "support"

# =============================================================================
# Docker app directories (Optional)
# =============================================================================

# Pre-create these directories owned by the deploy user.
# Required if deploying apps with apps-docker-cyberbits-opentofu, so that
# subdirectories can be created without a sudo password.
# Leave empty or omit if not needed.

# Changing this, needs tofu apply and the Ansible playbook to be ran

# docker_app_dirs = [
#   "/opt/nextcloud-apps",
#   "/opt/nginx-apps",
#   "/opt/traefik",
#   "/opt/wordpress-apps"
# ]

# =============================================================================
# SMTP configuration (Optional, for fail2ban email alerts)
# =============================================================================

# Uncomment and configure if you want fail2ban to send email alerts
# Supported providers: Gmail, ProtonMail, Outlook, SendGrid, etc.

# --- ProtonMail Example ---
# smtp_host     = "smtp.protonmail.ch"
# smtp_port     = 587
# smtp_user     = "your-email@protonmail.com"
# smtp_password = "your-smtp-token""   # Generate in ProtonMail Settings > Security > SMTP

# =============================================================================
# Firewall configuration
# =============================================================================
# Firewall must already exist in Hetzner Cloud.
# Create it first using https://github.com/cyberbitsorg/infra-hetzner-firewall
# then reference the firewall name here.

firewall_name = "main-web-firewall"
