# msmtp configuration for {{ fqdn }}
# Generated by Ansible

# Defaults
defaults
auth           on
tls            on
tls_starttls   on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        /var/log/msmtp.log

# SMTP account
account        default
host           {{ smtp_host }}
port           {{ smtp_port }}
from           {{ smtp_from }}
user           {{ smtp_user }}
password       {{ smtp_password }}
