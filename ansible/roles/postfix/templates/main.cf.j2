# Postfix main configuration
# Generated by Ansible for {{ fqdn }}

# Identity
myhostname = {{ fqdn }}
myorigin = {{ base_domain }}

# Listen on all interfaces so Docker containers can reach Postfix via host-gateway.
# Port 25 is blocked externally by UFW and Hetzner firewall — not an open relay.
inet_interfaces = all
inet_protocols = ipv4

# Relay all mail through ProtonMail
relayhost = [{{ smtp_host }}]:{{ smtp_port }}

# SASL authentication
smtp_sasl_auth_enable = yes
smtp_sasl_password_maps = hash:/etc/postfix/sasl_passwd
smtp_sasl_security_options = noanonymous
smtp_sasl_tls_security_options = noanonymous

# Enforce TLS
smtp_tls_security_level = encrypt
smtp_tls_CAfile = /etc/ssl/certs/ca-certificates.crt

# Rate limiting — prevents ProtonMail rate limit issues
smtp_destination_concurrency_limit = 1
smtp_destination_rate_delay = 5s
smtp_extra_recipient_limit = 10

# Sender rewriting
sender_canonical_maps = static:{{ smtp_from }}

# Trusted networks — localhost and Docker bridge ranges
mynetworks = 127.0.0.0/8 172.16.0.0/12

# Only allow relay from trusted networks, reject everything else
smtpd_relay_restrictions = permit_mynetworks reject

# No local mailboxes — null client
local_transport = error:local delivery disabled
mydestination =
