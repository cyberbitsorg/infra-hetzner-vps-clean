[DEFAULT]
bantime = {{ fail2ban_bantime | default(-1) }}
findtime = {{ fail2ban_findtime | default(86400) }}
maxretry = {{ fail2ban_maxretry | default(10) }}
backend = systemd
ignoreip = 127.0.0.1/8 ::1

# No real-time emails - weekly summary via cron instead
action = %(action_)s

[sshd]
enabled = true
port = 22
filter = sshd
logpath = /var/log/auth.log
maxretry = {{ fail2ban_maxretry | default(10) }}

[nginx-http-auth]
enabled = true
filter = nginx-http-auth
port = http,https
logpath = /var/log/nginx/error.log
