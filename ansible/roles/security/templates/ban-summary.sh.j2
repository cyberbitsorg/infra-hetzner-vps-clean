#!/bin/bash
# Weekly ban summary report for fail2ban
# Generated by Ansible

WEEK_AGO=$(date -d '7 days ago' '+%Y-%m-%d')

# Read current + rotated logs (.1, .2.gz, ...) so the 7-day window isn't
# truncated by weekly logrotate. zgrep handles plain and gzipped files.
LOGS=/var/log/fail2ban.log*

# All ban events this week (excluding recidive and Restore Ban replays)
BAN_PATTERN='NOTICE +\[(sshd|nginx[^]]*)\] Ban '
BAN_LINES=$(zgrep -hE "$BAN_PATTERN" $LOGS 2>/dev/null | awk -v week="$WEEK_AGO" '$1 >= week')
RECENT_BANS=$(echo "$BAN_LINES" | grep -c .)

# Unique IPs banned this week (non-recidive jails)
NEW_BANNED_IPS=$(echo "$BAN_LINES" | awk 'NF {print $NF}' | sort -u)
UNIQUE_IPS=$(echo "$NEW_BANNED_IPS" | grep -c .)
BANNED_IPS=$(echo "$NEW_BANNED_IPS" | grep . | sed 's/^/- /')
[ -z "$BANNED_IPS" ] && BANNED_IPS="(none)"

# IPs that hit the recidive jail this week (permanently banned)
RECIDIVE_PATTERN='NOTICE +\[recidive\] Ban '
RECIDIVE_THIS_WEEK=$(zgrep -hE "$RECIDIVE_PATTERN" $LOGS 2>/dev/null | awk -v week="$WEEK_AGO" '$1 >= week {print $1, $2, $NF}' | sort -u | grep .)
RECIDIVE_COUNT=$(echo "$RECIDIVE_THIS_WEEK" | grep -c .)
RECIDIVE_LIST=$(echo "$RECIDIVE_THIS_WEEK" | grep . | awk '{print "- " $3 " (banned " $1 " " $2 ")"}')
[ -z "$RECIDIVE_LIST" ] && RECIDIVE_LIST="(none)"

# Total permanently banned IPs (all time)
TOTAL_PERMANENT=$(fail2ban-client status recidive 2>/dev/null | grep 'Banned IP list' | sed 's/.*Banned IP list:\s*//' | tr ' ' '\n' | grep -c .)

# Create email
SUBJECT="Weekly Security Report - $(hostname)"
FROM="{{ smtp_from }}"
TO="{{ admin_email }}"

cat << EOF | /usr/sbin/sendmail -t
Subject: $SUBJECT
From: $FROM
To: $TO
Content-Type: text/plain; charset=UTF-8

=== WEEKLY FAIL2BAN SECURITY REPORT ===
Server: $(hostname -f)
Date: $(date)
Period: Last 7 days

=== NEWLY BANNED THIS WEEK ===
Unique IPs newly banned: $UNIQUE_IPS
Total ban events: $RECENT_BANS

Newly banned IP list:
$BANNED_IPS

=== PERMANENTLY BANNED (RECIDIVE) ===
New permanent bans this week: $RECIDIVE_COUNT
Total permanently banned IPs: $TOTAL_PERMANENT

New permanent bans this week:
$RECIDIVE_LIST

=== NOTES ===
- First offense: {{ (fail2ban_bantime / 86400) | int }} day(s) ban, after {{ fail2ban_maxretry }} failed attempts within {{ (fail2ban_findtime / 3600) | int }} hours
- Recidive: permanent ban after being caught 3 times within 7 days
- To unban a temporary IP: fail2ban-client set sshd unbanip <IP>
- To unban a permanent IP: fail2ban-client set recidive unbanip <IP>

EOF
